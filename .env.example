# Copy this to .env.local and adjust as needed

# Base API URL (leave empty for local Next.js API routes)
NEXT_PUBLIC_API_URL=

# Demo: Toggle simulated network latency (set false for instant responses)
NEXT_PUBLIC_SIMULATE_LATENCY=true

# Demo: Latency in ms (jitter applied: value to value*1.5)
NEXT_PUBLIC_LATENCY_MS=500
